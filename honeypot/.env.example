# Local development – copy to .env and adjust as needed
#   cp .env.example .env

# SSH server
HOST=0.0.0.0
PORT=2223
SEED_PATH=state_templates/state.json
SESSIONS_ROOT=runtime_logs/sessions
HOST_KEY_PATH=ssh_host_key

# ChromaDB start with, docker run -d -p 8000:8000 chromadb/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=shell_context

KB_PATH=../rag-corpus/out/kb_docs_v1.jsonl

# Ollama (optional, set USE_LLM_RENDERER=true for LLM output rendering)
USE_LLM_RENDERER=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b #llama3.1:8b
# Debug: set DEBUG_LLM=true to log Ollama prompts/responses to stderr
DEBUG_LLM=false
FORCE_BAD_LLM=false
FORCE_DETERMINISTIC=false
FORCE_NEW_SESSION=true