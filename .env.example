# decop-llm-honey — deployment environment
# Copy to .env before starting the stack:  cp .env.example .env

# Docker deployment: all services read this file via env_file.
# Local development: copy to honeypot/.env instead and use run_local.sh.

# Address and port for the main honeypot server
HOST=0.0.0.0
PORT=2223

# Port for the baseline (prompt-only) server
PORT_BASELINE=2224

# Path to the seed state template (copied fresh per session)
SEED_PATH=state_templates/state.json

# Where per-session state directories are created
SESSIONS_ROOT=runtime_logs/sessions

# RSA host key path (auto-generated if missing)
HOST_KEY_PATH=ssh_host_key


# true = state_isolated variant, false = deterministic_only variant
USE_LLM_RENDERER=true

# Use to activate deterministic_only variant without changing USE_LLM_RENDERER (no LLM calls)
FORCE_DETERMINISTIC=false

# Ollama must run on the HOST machine (not inside Docker).
OLLAMA_URL=http://host.docker.internal:11434

OLLAMA_MODEL=qwen2.5:7b

# Maximum tokens the LLM generates per response
OLLAMA_MAX_TOKENS=160

# Request timeout in seconds (LLM fallback triggers on timeout)
OLLAMA_TIMEOUT_SECONDS=60

# Send requests with format=json to Ollama
OLLAMA_JSON_FORMAT=true

# Set to true to log the full Ollama prompt and response to stderr
DEBUG_LLM=false

# Testing only: forces the LLM to return "bad output\n" (exercises fallback path)
FORCE_BAD_LLM=false

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=shell_context

# Run ingest_chroma.py on container startup (loads RAG corpus into ChromaDB)
# Keep true for Docker deployment
RUN_CHROMA_INGEST_ON_STARTUP=true

# Path to the knowledge base JSONL (used in run_local.sh)
KB_PATH=../rag-corpus/out/kb_docs_v1.jsonl

# IMPORTANT: Must be true during all evaluation runs.
# Without this, consecutive scenario_runner connections reuse the same session
# file and mix events.jsonl entries, corrupting all computed metrics.
FORCE_NEW_SESSION=true
